PORT=4601
MONGODB_URI=mongodb://127.0.0.1:27017/sealed_db

# Webhook signature secret (shared with Snovia sender)
SEALED_WEBHOOK_SECRET=change_me

# Problems server URL for auto-error logging
SEALED_PROBLEMS_URL=http://localhost:4600/api/problems

# Hardhat local chain settings
HARDHAT_RPC_URL=http://127.0.0.1:8545
HARDHAT_PRIVATE_KEY=
HARDHAT_CONTRACT_ADDRESS=
SEALED_CHAIN_MODE=mock

# SMTP for reliable delivery (set in real usage)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=sealed@local.dev

# Portal links
SEALED_PORTAL_BASE_URL=http://localhost:5174

# Comma-separated list of allowed web origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
NODE_ENV=development
